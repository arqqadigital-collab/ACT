{
  "collectionName": "components_shared_intelligence_feature_items",
  "info": {
    "displayName": "Intelligence Feature Item",
    "description": "A single business intelligence feature with id, title, description and image",
    "icon": "chartLine"
  },
  "options": {},
  "attributes": {
    "featureId": {
