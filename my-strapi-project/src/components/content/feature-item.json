{
  "collectionName": "components_content_feature_items",
  "info": {
    "displayName": "Feature Item",
    "description": "Feature or expertise item with icon, title and description"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "iconName": {
      "type": "string",
      "required": false,
      "default": "CheckCircle"
    }
  }
}
