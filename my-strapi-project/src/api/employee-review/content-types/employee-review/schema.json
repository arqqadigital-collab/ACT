{
  "kind": "collectionType",
  "collectionName": "employee_reviews",
  "info": {
    "singularName": "employee-review",
    "pluralName": "employee-reviews",
    "displayName": "Employee Review",
    "description": "Employee testimonials and reviews"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "jobTitle": {
      "type": "string",
      "required": true
    },
    "yearsAtCompany": {
      "type": "string",
      "required": true
    },
    "quote": {
      "type": "text",
      "required": true
    },
    "rating": {
      "type": "integer",
      "default": 5,
      "min": 1,
      "max": 5
    },
    "displayOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
