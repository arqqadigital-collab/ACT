{
  "kind": "collectionType",
  "collectionName": "jobs",
  "info": {
    "singularName": "job",
    "pluralName": "jobs",
    "displayName": "Job Opening",
    "description": "Job openings and career opportunities"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "department": {
      "type": "string",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "jobType": {
      "type": "enumeration",
      "enum": ["Full Time", "Part Time", "Contract", "Internship"],
      "default": "Full Time",
      "required": true
    },
    "experienceLevel": {
      "type": "enumeration",
      "enum": ["Entry Level", "Mid Level", "Senior Level", "Lead"],
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "responsibilities": {
      "type": "richtext",
      "required": true
    },
    "requirements": {
      "type": "richtext",
      "required": true
    },
    "niceToHave": {
      "type": "richtext"
    },
    "benefits": {
      "type": "richtext"
    },
    "salaryRange": {
      "type": "string"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "postedDate": {
      "type": "date"
    },
    "applicationDeadline": {
      "type": "date"
    }
  }
}
